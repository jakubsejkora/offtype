<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Non-sandboxed: App Sandbox is incompatible with CGEventTap / Accessibility
         injection, which Offtype's hotkey + text injection require. Distribution
         is via Developer ID + hardened runtime + notarization, not the App Store. -->
    <key>com.apple.security.app-sandbox</key>
    <false/>
</dict>
</plist>
